<!DOCTYPE html>
<html>
<head>
    <title>Complete Form with CSS, Bootstrap & JavaScript</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" 
    rel="stylesheet">

    <!-- Custom CSS -->
    <style>
        body {
            background-color: #f2f6ff;
            font-family: Arial, sans-serif;
        }

        .form-container {
            background: white;
            width: 60%;
            margin: auto;
            margin-top: 30px;
            padding: 25px;
            border-radius: 10px;
            border: 2px solid #0d6efd;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }

        fieldset {
            border: 2px solid #0d6efd;
            border-radius: 5px;
            padding: 20px;
        }

        legend {
            color: #0d6efd;
            font-weight: bold;
            font-size: 18px;
        }
    </style>
</head>

<body>

    <div class="container form-container">

        <h2 class="text-center mb-4">Contact & Job Interest Form</h2>

        <!-- FORM START -->
        <form onsubmit="return validateForm()">

            <!-- Contact Info -->
            <fieldset class="mb-4">
                <legend>Contact Info</legend>

                <label class="form-label">Username:</label>
                <input type="text" id="username" class="form-control mb-3">

                <label class="form-label">Email:</label>
                <input type="text" id="email" class="form-control mb-3">

                <label class="form-label">Telephone:</label>
                <input type="text" id="telephone" class="form-control mb-3">
            </fieldset>

            <!-- Checkboxes -->
            <fieldset class="mb-4">
                <legend>Job Positions (Select all that apply)</legend>

                <div class="form-check">
                    <input type="checkbox" id="account_exec" class="form-check-input" name="jobs">
                    <label class="form-check-label" for="account_exec">Account Executive</label>
                </div>

                <div class="form-check">
                    <input type="checkbox" id="business_dev" class="form-check-input" name="jobs">
                    <label class="form-check-label" for="business_dev">Business Development</label>
                </div>

                <div class="form-check">
                    <input type="checkbox" id="inside_sales" class="form-check-input" name="jobs">
                    <label class="form-check-label" for="inside_sales">Inside Sales</label>
                </div>

                <div class="form-check">
                    <input type="checkbox" id="sales_manager" class="form-check-input" name="jobs">
                    <label class="form-check-label" for="sales_manager">Sales Manager</label>
                </div>

                <div class="form-check">
                    <input type="checkbox" id="vp_sales" class="form-check-input" name="jobs">
                    <label class="form-check-label" for="vp_sales">VP Sales</label>
                </div>
            </fieldset>

            <!-- Additional Controls -->
            <fieldset class="mb-4">
                <legend>Additional Details</legend>

                <label class="form-label">Type of Position:</label>
                <select id="position_type" class="form-select mb-3">
                    <option value="">-- Select position type --</option>
                    <option>Part-time contract</option>
                    <option>Part-time permanent</option>
                    <option>Full-time contract</option>
                    <option>Full-time permanent</option>
                </select>

                <label class="form-label">Willing to relocate?</label><br>

                <div class="form-check">
                    <input type="radio" id="relocate_yes" name="relocate" class="form-check-input">
                    <label class="form-check-label" for="relocate_yes">Yes</label>
                </div>

                <div class="form-check">
                    <input type="radio" id="relocate_no" name="relocate" class="form-check-input">
                    <label class="form-check-label" for="relocate_no">No</label>
                </div>

            </fieldset>

            <!-- Buttons -->
            <button type="submit" class="btn btn-primary">Submit</button>
            <button type="reset" class="btn btn-secondary ms-2">Reset</button>

        </form>
        <!-- FORM END -->

    </div>

    <!-- JavaScript Validation -->
    <script>
        function validateForm() {
            let name = document.getElementById("username").value;
            let email = document.getElementById("email").value;
            let phone = document.getElementById("telephone").value;

            // Check if name, email, or telephone are empty
            if (name === "" || email === "" || phone === "") {
                alert("Please complete all required fields (Username, Email, Telephone)");
                return false;
            }

            // Check at least ONE checkbox is selected
            let checkboxes = document.getElementsByName("jobs");
            let checked = false;

            for (let i = 0; i < checkboxes.length; i++) {
                if (checkboxes[i].checked) {
                    checked = true;
                    break;
                }
            }

            if (!checked) {
                alert("Please select at least one job position.");
                return false;
            }

            return true; // allow form submission
        }
    </script>

</body>
</html>
